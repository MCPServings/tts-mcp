# RedQueen TTS gateway — environment template
# Copy to /opt/redqueen-tts/.env on latex-tools (chmod 600, owner www-data).

# Optional bearer key for direct callers. Empty = open (dev).
TTS_API_KEY=
# Optional RapidAPI proxy secret (set if listing on RapidAPI).
TTS_RAPIDAPI_PROXY_SECRET=

# Per-backend upstream timeout (seconds).
TTS_TIMEOUT=120
TTS_PUBLIC_NAME=redqueen-tts

# Backend routing table. Each value points at a reverse-tunnel local port on
# latex-tools that forwards to the matching container on halo-office.
#   kind=openai  -> backend exposes POST /v1/audio/speech (forward as-is)
#   kind=raw     -> backend exposes POST <path> {text,voice,format} -> audio
TTS_BACKENDS={"kokoro":{"url":"http://127.0.0.1:8321","kind":"openai","upstream_model":"kokoro","default_voice":"af_heart","languages":["en","zh","ja","es","fr"],"note":"Kokoro-82M apache-2.0"},"melotts":{"url":"http://127.0.0.1:8322","kind":"raw","path":"/tts","default_voice":"EN-Default","languages":["en","zh","ja","ko","fr","es"],"note":"MeloTTS MIT"},"qwen3-tts-1.7b":{"url":"http://127.0.0.1:8323","kind":"raw","path":"/tts","languages":["zh","en","ja","ko","de","fr","ru","pt","es","it"],"note":"Qwen3-TTS-1.7B apache-2.0, voice clone"},"qwen3-tts-0.6b":{"url":"http://127.0.0.1:8324","kind":"raw","path":"/tts","languages":["zh","en","ja","ko","de","fr","ru","pt","es","it"],"note":"Qwen3-TTS-0.6B apache-2.0"},"cosyvoice3":{"url":"http://127.0.0.1:8325","kind":"raw","path":"/tts","languages":["zh","en","fr","es","ja","ko","it","ru","de"],"note":"CosyVoice3-0.5B apache-2.0, voice clone"},"cosyvoice2":{"url":"http://127.0.0.1:8326","kind":"raw","path":"/tts","languages":["zh","en","fr","es","ja","ko","it","ru","de"],"note":"CosyVoice2-0.5B apache-2.0"},"indextts2":{"url":"http://127.0.0.1:8327","kind":"raw","path":"/tts","languages":["en","zh"],"note":"IndexTTS-2 bilibili license, voice clone + emotion"},"orpheus":{"url":"http://127.0.0.1:8328","kind":"raw","path":"/tts","languages":["en"],"note":"Orpheus-3B apache-2.0, voice clone"},"dia":{"url":"http://127.0.0.1:8329","kind":"raw","path":"/tts","languages":["en"],"note":"Dia-1.6B apache-2.0, dialogue"}}

# ---------------------------------------------------------------------------
# MCP server (mcp_server.py) — optional, only used when running the MCP front-end
# ---------------------------------------------------------------------------
# Transport: streamable-http (remote, behind nginx) or stdio (local spawn).
TTS_MCP_TRANSPORT=streamable-http
# Where the MCP server reaches the gateway above (this same host).
TTS_MCP_GATEWAY=http://127.0.0.1:18821
TTS_MCP_HOST=127.0.0.1
TTS_MCP_PORT=18822
# Comma-separated Host allowlist for MCP DNS-rebinding protection. Must include
# the public domain(s) when served behind nginx. Use "*" to disable the check.
TTS_MCP_ALLOWED_HOSTS=api.redqueen-serving.cloud,tts.redqueen-serving.cloud,127.0.0.1,127.0.0.1:18822,localhost
# Per-IP rate limits (per minute) and global synthesis concurrency cap.
TTS_MCP_RL_SYNTH=15
TTS_MCP_RL_READ=60
TTS_MCP_MAX_CONCURRENCY=4
